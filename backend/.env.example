# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/truelens

# Redis Configuration (Leave blank for in-memory mock fallback)
REDIS_URL=redis://localhost:6379/0

# Gemini API Key (Required for analysis)
GEMINI_API_KEY=your_gemini_api_key_here

# Clerk Authentication (Required)
CLERK_SECRET_KEY=your_clerk_secret_key_here

# CORS Origins (Comma separated for production)
BACKEND_CORS_ORIGINS=http://localhost:3000,https://your-frontend-domain.vercel.app
