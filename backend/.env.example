# TrueLens Backend Environment Variables Template
# Copy this file to .env and configure details

# PostgreSQL Connection String (Neon or Local Docker)
DATABASE_URL=postgresql+asyncpg://postgres:postgrespassword@localhost:5432/truelens

# Redis Server URL
REDIS_URL=redis://localhost:6379/0

# ChromaDB stand-alone server configurations
CHROMA_HOST=localhost
CHROMA_PORT=8000
GOOGLE_FACT_CHECK_API_KEY=
